{
  "name": "agent-readiness-auditor",
  "version": "0.1.1",
  "description": "Scan any website and score how ready — and how safe — it is for AI agents.",
  "type": "module",
  "bin": {
    "agent-audit": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "audit": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agents",
    "llms-txt",
    "prompt-injection",
    "agentic-web",
    "governance"
  ],
  "author": "Asish Singh (@asish-singh)",
  "license": "MIT",
  "homepage": "https://github.com/asish-singh/agent-readiness-auditor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asish-singh/agent-readiness-auditor.git"
  },
  "bugs": {
    "url": "https://github.com/asish-singh/agent-readiness-auditor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
